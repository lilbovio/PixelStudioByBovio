# ─────────────────────────────────────────────────────────────
# PIXEL STUDIO BY BOVIO — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# WhatsApp number in international format without + or spaces
# Example: 5233293915329  (52 = Mexico, 33 = Guadalajara, then the number)
NEXT_PUBLIC_WHATSAPP_NUMBER=5233293915329

# Canonical site URL — no trailing slash
NEXT_PUBLIC_SITE_URL=https://pixelstudiobybovio.lat

